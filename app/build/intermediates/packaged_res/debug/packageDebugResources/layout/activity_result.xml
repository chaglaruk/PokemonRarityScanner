<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_stitch_card_high"
    android:padding="20dp"
    android:layout_margin="12dp">

    <!-- Top accent line -->
    <View android:layout_width="match_parent" android:layout_height="2dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_accent_line" />

    <!-- Pokemon name + score hero row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ANALYSIS RESULT"
                android:textColor="#AC8880" android:textSize="9sp"
                android:textStyle="bold" android:layout_marginBottom="4dp" />

            <EditText android:id="@+id/etPokemonName"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Pokemon name"
                android:textColor="#E5E2E1" android:textSize="28sp"
                android:textStyle="bold" android:fontFamily="sans-serif-black"
                android:background="@android:color/transparent"
                android:padding="0dp" android:inputType="textCapWords" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutScoreCircle"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_score_circle"
            android:gravity="center"
            android:orientation="vertical">

            <TextView android:id="@+id/tvScore"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="@color/white"
                android:textSize="28sp" android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <TextView android:id="@+id/tvTier"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/common"
                android:textColor="@color/tier_common"
                android:textSize="9sp" android:textStyle="bold" android:textAllCaps="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- CP / HP / IV row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_stitch_card"
        android:padding="16dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:paddingEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CP" android:textColor="#AC8880"
                android:textSize="9sp" android:textStyle="bold" />
            <EditText android:id="@+id/etCP"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="—" android:textColor="#E5E2E1" android:textSize="22sp"
                android:textStyle="bold" android:background="@android:color/transparent"
                android:padding="0dp" android:inputType="number" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="#33FFFFFF" android:layout_marginEnd="8dp" />

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:paddingStart="8dp" android:paddingEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HP" android:textColor="#AC8880"
                android:textSize="9sp" android:textStyle="bold" />
            <EditText android:id="@+id/etHP"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="—" android:textColor="#E5E2E1" android:textSize="22sp"
                android:textStyle="bold" android:background="@android:color/transparent"
                android:padding="0dp" android:inputType="number" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="#33FFFFFF" android:layout_marginEnd="8dp" />

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:paddingStart="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="IV EST." android:textColor="#AC8880"
                android:textSize="9sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvIVEstimate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#E3350D"
                android:textSize="22sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Caught date -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:layout_marginBottom="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CAUGHT DATE" android:textColor="#AC8880"
            android:textSize="9sp" android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/etDate"
            android:layout_width="match_parent" android:layout_height="40dp"
            android:hint="—" android:textColor="#E5E2E1" android:textSize="15sp"
            android:background="@drawable/bg_stitch_card"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:inputType="date" />
    </LinearLayout>

    <!-- Rarity analysis -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="RARITY ANALYSIS" android:textColor="#AC8880"
        android:textSize="9sp" android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_stitch_card"
        android:padding="12dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:id="@+id/tvExplanations"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Analyzing rarity factors..."
                android:textSize="13sp" android:lineSpacingExtra="6dp"
                android:textColor="#E5E2E1" />
        </LinearLayout>
    </ScrollView>

    <!-- Action buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:id="@+id/btnBack"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="@string/back" android:textColor="#E5E2E1"
            android:background="@drawable/bg_stitch_card"
            app:cornerRadius="24dp" />

        <Button android:id="@+id/btnSave"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="@string/save" android:textColor="@color/white"
            android:backgroundTint="#E3350D"
            app:cornerRadius="24dp" />

        <Button android:id="@+id/btnShare"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/share" android:textColor="#E5E2E1"
            android:background="@drawable/bg_stitch_card"
            app:cornerRadius="24dp" />
    </LinearLayout>

</LinearLayout>
