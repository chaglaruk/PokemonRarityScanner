<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="20dp"
    android:layout_margin="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Scan Result"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <View
            android:id="@+id/dragHandle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@color/text_hint"
            android:layout_gravity="center_vertical" />
    </LinearLayout>

    <!-- Pokemon Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pokemon Name"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etPokemonName"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Pokemon name"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/edit_text_bg"
            android:padding="8dp"
            android:layout_marginBottom="12dp" />

        <!-- CP and HP Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CP"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etCP"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:hint="CP"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/edit_text_bg"
                    android:padding="8dp"
                    android:inputType="number" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HP"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etHP"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:hint="HP"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/edit_text_bg"
                    android:padding="8dp"
                    android:inputType="number" />
            </LinearLayout>
        </LinearLayout>

        <!-- IV Estimate (New) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IV Estimate: "
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
                
            <TextView
                android:id="@+id/tvIVEstimate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculating..."
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Caught Date"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etDate"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Caught date"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/edit_text_bg"
            android:padding="8dp"
            android:inputType="date"
            android:layout_marginBottom="16dp" />
    </LinearLayout>

    <!-- Score Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layoutScoreCircle"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_score_circle"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_gravity="center">

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/tvTier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common"
                    android:textColor="@color/tier_common"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="true" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Why is it rare? (New) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rarity Analysis"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:background="@drawable/edit_text_bg"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvExplanations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Analyzing rarity factors..."
                android:textSize="13sp"
                android:lineSpacingExtra="6dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Raw Debug Data"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/pokeball_red"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvRawDebugData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Raw data loading..."
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/back"
            android:textColor="@color/text_primary"
            android:background="@android:color/transparent"
            app:cornerRadius="24dp"
            app:strokeColor="@color/text_hint"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/save"
            android:textColor="@color/text_primary"
            android:background="@android:color/transparent"
            app:cornerRadius="24dp"
            app:strokeColor="@color/text_hint"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btnShare"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/share"
            android:textColor="@color/text_primary"
            android:background="@android:color/transparent"
            app:cornerRadius="24dp"
            app:strokeColor="@color/text_hint"
            app:strokeWidth="1dp" />
    </LinearLayout>

</LinearLayout>
