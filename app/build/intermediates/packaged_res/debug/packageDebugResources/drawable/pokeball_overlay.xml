<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow circle (slightly offset) -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="oval">
            <solid android:color="#44000000" />
        </shape>
    </item>

    <!-- White bottom half (full circle base) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <stroke
                android:width="2dp"
                android:color="#333333" />
        </shape>
    </item>

    <!-- Red top half -->
    <item android:bottom="30dp">
        <shape android:shape="rectangle">
            <solid android:color="#E3350D" />
            <corners
                android:topLeftRadius="100dp"
                android:topRightRadius="100dp" />
        </shape>
    </item>

    <!-- Center horizontal black line -->
    <item
        android:bottom="28dp"
        android:top="28dp">
        <shape android:shape="rectangle">
            <solid android:color="#333333" />
        </shape>
    </item>

    <!-- Center button circle (outer ring) -->
    <item
        android:bottom="21dp"
        android:left="21dp"
        android:right="21dp"
        android:top="21dp">
        <shape android:shape="oval">
            <solid android:color="#333333" />
        </shape>
    </item>

    <!-- Center button circle (inner white) -->
    <item
        android:bottom="23dp"
        android:left="23dp"
        android:right="23dp"
        android:top="23dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#333333" />
        </shape>
    </item>

</layer-list>
