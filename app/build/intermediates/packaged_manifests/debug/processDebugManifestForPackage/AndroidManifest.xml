<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.pokerarity.scanner"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="35" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <permission
        android:name="com.pokerarity.scanner.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.pokerarity.scanner.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:name="com.pokerarity.scanner.PokeRarityApp"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@drawable/ic_pokeball"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_pokeball"
        android:supportsRtl="true"
        android:theme="@style/Theme.PokeRarityScanner" >
        <activity
            android:name="com.pokerarity.scanner.ui.splash.SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.PokeRarityScanner" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.pokerarity.scanner.ui.main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.PokeRarityScanner" />
        <activity
            android:name="com.pokerarity.scanner.ui.permission.ProjectionPermissionActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:noHistory="true"
            android:theme="@style/Theme.Translucent.NoTitleBar" />
        <activity
            android:name="com.pokerarity.scanner.ui.result.ResultActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleInstance"
            android:theme="@style/Theme.PokeRarityScanner" />
        <activity
            android:name="com.pokerarity.scanner.ui.result.HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.PokeRarityScanner" />

        <!-- OverlayService: specialUse type — starts without a projection token -->
        <service
            android:name="com.pokerarity.scanner.service.OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse" >
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Screen overlay for scanning" />
        </service>

        <!--
            ScreenCaptureService: declares BOTH specialUse and mediaProjection types.
            onCreate() starts with SPECIAL_USE (no token needed).
            setupProjection() promotes to MEDIA_PROJECTION once token is valid.
            Android 14 requires the declared type(s) to cover whatever type is passed
            to startForeground() at runtime.
        -->
        <service
            android:name="com.pokerarity.scanner.service.ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="specialUse|mediaProjection" >
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Screen capture for Pokemon GO scanner" />
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.pokerarity.scanner.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true" >
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name="com.pokerarity.scanner.ui.debug.ScanFixtureExportReceiver"
            android:enabled="true"
            android:exported="true" >
            <intent-filter>
                <action android:name="com.pokerarity.scanner.EXPORT_SCAN_FIXTURES" />
            </intent-filter>
        </receiver>

        <activity
            android:name="androidx.compose.ui.tooling.PreviewActivity"
            android:exported="true" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.pokerarity.scanner.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <activity
            android:name="androidx.activity.ComponentActivity"
            android:exported="true" />

        <service
            android:name="androidx.room.MultiInstanceInvalidationService"
            android:directBootAware="true"
            android:exported="false" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>